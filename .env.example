# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

# ── Option A: URL without password (recommended if password has special chars) ──
# Put a placeholder in DATABASE_URL and set the real password in DB_PASSWORD.
# DB_PASSWORD is injected at runtime so no URL-encoding is needed.
DATABASE_URL=postgresql://postgres@db.YOUR-PROJECT-REF.supabase.co:5432/postgres
DB_PASSWORD=your-raw-password-here

# ── Option B: Full URL (only if password has no special characters) ──
# DATABASE_URL=postgresql://postgres:simplepassword@db.xxx.supabase.co:5432/postgres

# Flask secret key (change in production)
SECRET_KEY=banka-dss-2024-secret
