# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

# PostgreSQL connection string from Supabase / Neon / Railway etc.
# Supabase format:  postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Neon format:      postgresql://[USER]:[PASSWORD]@[HOST]/[DBNAME]?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Flask secret key (change in production)
SECRET_KEY=banka-dss-2024-secret
